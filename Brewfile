brew "wget"
brew "curl"
brew "telnet"

# ── System Utilities ──
brew "coreutils"
brew "grep"
brew "tree"
brew "screen"
brew "screenresolution"

# ── Media / Image Processing ──
brew "ffmpeg"
brew "imagemagick"
brew "tesseract"
