# ============================================================
# Brewfile — brew でしか管理できないものだけ
#
# ランタイム・CLI ツールは mise で管理 (~/.config/mise/config.toml)
# npm CLIs は pnpm (mise npm backend) で管理
# Python CLIs は uv tool で管理
# ============================================================

# ── Taps ──
tap "koekeishiya/formulae"

# ── macOS Window Management ──
brew "yabai"
brew "skhd"

# ── Editor ──
